<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo2.DashboardController">

    <left>
        <VBox prefWidth="220.0" style="-fx-background-color: #800000;" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="10.0">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                    <children>
                        <Label text="🔍" textFill="WHITE">
                            <font>
                                <Font size="22.0" />
                            </font>
                        </Label>
                        <Label text="FindIT" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets left="15.0" right="15.0" top="30.0" />
                    </padding>
                    <children>
                        <Button fx:id="btnNavDashboard" alignment="BASELINE_LEFT" graphicTextGap="15.0" mnemonicParsing="false" onAction="#handleNavigation" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #FFCC00; -fx-cursor: hand;" text="Dashboard">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                            <graphic>
                                <Label text="☩" textFill="#FFCC00"><font><Font size="18.0" /></font></Label>
                            </graphic>
                        </Button>

                        <Button fx:id="btnNavItems" alignment="BASELINE_LEFT" graphicTextGap="15.0" mnemonicParsing="false" onAction="#handleNavigation" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #FFFFFF; -fx-cursor: hand;" text="Items">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                            <graphic>
                                <Label text="☰" textFill="WHITE"><font><Font size="16.0" /></font></Label>
                            </graphic>
                        </Button>

                        <Button fx:id="btnNavReport" alignment="BASELINE_LEFT" graphicTextGap="15.0" mnemonicParsing="false" onAction="#handleNavigation" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #FFFFFF; -fx-cursor: hand;" text="Report">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                            <graphic>
                                <Label text="📋" textFill="WHITE"><font><Font size="16.0" /></font></Label>
                            </graphic>
                        </Button>
                    </children>
                </VBox>

                <VBox alignment="BOTTOM_LEFT" spacing="10.0">
                    <padding>
                        <Insets bottom="30.0" left="15.0" right="15.0" />
                    </padding>
                    <children>
                        <Button fx:id="btnNavHelp" alignment="BASELINE_LEFT" graphicTextGap="15.0" mnemonicParsing="false" onAction="#handleNavigation" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #FFFFFF; -fx-cursor: hand;" text="Help">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                            <graphic>
                                <Label text="❓" textFill="WHITE"><font><Font size="16.0" /></font></Label>
                            </graphic>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <VBox prefHeight="200.0" prefWidth="1000.0" style="-fx-background-color: #FFFFFF;" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: #800000;">
                    <padding>
                        <Insets left="30.0" />
                    </padding>
                    <children>
                        <Label text="Dashboard" textFill="#FFCC00">
                            <font>
                                <Font name="System Bold" size="26.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <VBox alignment="CENTER" spacing="30.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label alignment="CENTER" text="Campus Lost and Found&#10;Reporting System" textAlignment="CENTER" textFill="#4A1515">
                            <font>
                                <Font name="System Bold" size="36.0" />
                            </font>
                        </Label>

                        <HBox alignment="CENTER" spacing="25.0">
                            <children>
                                <Button fx:id="btnReportLost" mnemonicParsing="false" onAction="#handleReportLost" prefHeight="50.0" prefWidth="220.0" style="-fx-background-color: #FFCC00; -fx-background-radius: 25; -fx-text-fill: #4A1515; -fx-cursor: hand;" text="Report Lost Item">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnReportFound" mnemonicParsing="false" onAction="#handleReportFound" prefHeight="50.0" prefWidth="220.0" style="-fx-background-color: #FFCC00; -fx-background-radius: 25; -fx-text-fill: #4A1515; -fx-cursor: hand;" text="Report Found Item">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Button>
                            </children>
                            <VBox.margin>
                                <Insets bottom="10.0" />
                            </VBox.margin>
                        </HBox>

                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" prefHeight="45.0" prefWidth="350.0" style="-fx-border-color: #4A1515; -fx-border-radius: 25; -fx-background-radius: 25; -fx-background-color: white;">
                                    <padding>
                                        <Insets left="15.0" right="15.0" />
                                    </padding>
                                    <children>
                                        <Label text="🔍" textFill="#4A1515" />
                                        <TextField fx:id="txtSearch" promptText="Search for lost and found items" style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </TextField>
                                    </children>
                                </HBox>

                                <Button fx:id="btnFilter" mnemonicParsing="false" onAction="#handleFilter" prefHeight="45.0" prefWidth="120.0" style="-fx-background-color: white; -fx-border-color: #4A1515; -fx-border-radius: 25; -fx-background-radius: 25; -fx-text-fill: #4A1515; -fx-cursor: hand;" text="  Filter">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                    <graphic>
                                        <Label text="▼" textFill="#800000" />
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="50.0" />
                    </padding>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>