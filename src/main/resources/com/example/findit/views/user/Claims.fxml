<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.findit.controllers.user.ClaimsController">
   
   <left>
      <fx:include source="DashboardSidebar.fxml" />
   </left>
   
   <center>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: #800000; -fx-padding: 0 0 0 30;">
               <children>
                  <Label style="-fx-font-size: 26; -fx-font-weight: bold;" text="Claims" textFill="#FFCC00" />
               </children>
            </HBox>
            
            <VBox spacing="20.0" style="-fx-padding: 25 30 25 30;" VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 15 20 15 20;">
                     <children>
                        <TextField promptText="🔍 Search items ..." style="-fx-background-color: transparent; -fx-border-color: #CCCCCC; -fx-border-radius: 8; -fx-padding: 8;" HBox.hgrow="ALWAYS" />
                        <ComboBox prefWidth="240.0" promptText="All Status" style="-fx-background-color: transparent; -fx-border-color: #CCCCCC; -fx-border-radius: 8; -fx-padding: 5;" />
                     </children>
                  </HBox>
                  
                  <FlowPane hgap="20.0" vgap="20.0" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>
